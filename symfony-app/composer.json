{
  "name": "zadanie/symfony-app",
  "type": "project",
  "require": {
    "php": "^8.1",
    "doctrine/annotations": "^2.0",
    "doctrine/doctrine-bundle": "^2.10",
    "doctrine/doctrine-migrations-bundle": "^3.6",
    "doctrine/orm": "^2.16",
    "symfony/asset": "*",
    "symfony/dotenv": "*",
    "symfony/flex": "^2.10",
    "symfony/form": "*",
    "symfony/framework-bundle": "*",
    "symfony/http-client": "*",
    "symfony/monolog-bundle": "^3.9",
    "symfony/runtime": "*",
    "symfony/security-bundle": "*",
    "symfony/security-csrf": "*",
    "symfony/serializer": "*",
    "symfony/skeleton": "*",
    "symfony/twig-bundle": "*",
    "symfony/validator": "*",
    "symfony/yaml": "*"
  },
  "require-dev": {
    "dama/doctrine-test-bundle": "^8.4",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^10.5",
    "slevomat/coding-standard": "^8.28",
    "symfony/browser-kit": "*",
    "symfony/css-selector": "*",
    "symfony/maker-bundle": "^1.53",
    "symfony/phpunit-bridge": "^8.0",
    "symfony/web-profiler-bundle": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "classmap": [
      "src/",
      "migrations/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "symfony/flex": true,
      "symfony/runtime": true
    }
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ],
    "phpcs": "vendor/bin/phpcs",
    "test": "vendor/bin/phpunit",
    "pre-commit": [
      "@phpcs",
      "@test"
    ]
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "6.4.*"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
